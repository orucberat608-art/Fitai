          arka plan: `radyal-gradyan(ellips, ${plan.color}0f 0%, şeffaf 70%)`,
          işaretçiOlayları: "yok", geçiş: "arka plan 0,5s",
        }} />
        <p style={{ fontSize: 11, letterSpacing: 4, textTransform: "uppercase", color: plan.color, marginBottom: 16, animation: "fadeUp 0.7s 0.1s both", transition: "color 0.3s" }}>
          Yapay Zeka Destekli Kişisel Koçluk
        </p>
        <h1 style={{
          fontFamily: "'Bebas Neue', sans-serif", fontSize: "clamp(48px, 8vw, 82px)",
          satır yüksekliği: 0,92, harf aralığı: 2, alt kenar boşluğu: 14, animasyon: "fadeUp 0,7s 0,2s her ikisi de",
        }}>
          PREMIUM'UNUZ<br />
          <span style={{ WebkitTextStroke: "1px rgba(255,255,255,0.22)", color: "transparent" }}>MENTOR.</span>
        </h1>
        <p style={{ color: "#555", fontSize: 14, maxWidth: 360, margin: "0 auto", lineHeight: 1.7, animation: "fadeUp 0.7s 0.3s both" }}>
          Bir sohbet robotu değil. Potansiyelinizi bilen ve daha azıyla yetinmenize izin vermeyecek bir arkadaş.
        </p>
      </div>

      {/* â”—â”€ Sohbet â”—â”€ */}
      <div style={{ maxWidth: 720, width: "100%", margin: "0 auto", padding: "0 20px 80px", flex: 1 }}>
        <div style={{
          arka plan: "#111", kenarlık: "1px solid rgba(255,255,255,0.07)",
          borderRadius: 24, overflow: "hidden", boxShadow: "0 40px 80px rgba(0,0,0,0.5)",
        }}>
          {/* Sohbet başlığı */}
          <div style={{
            display: "flex", alignItems: "center", justifyContent: "space-between",
            dolgu: "16px 24px", alt kenarlık: "1px düz rgba(255,255,255,0.07)",
          }}>
            <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
              <div style={{
                genişlik: 8, yükseklik: 8, kenar yarıçapı: "%50",
                Arka plan: plan.color, kutu gölgesi: `0 0 10px ${plan.color}`,
                animasyon: "sonsuz 2 saniyelik darbe", geçiş: "0,3 saniyelik arka plan",
              }} />
              <span style={{ fontSize: 13, color: "#555" }}>
                FIT çevrimiçi koçluk hizmeti sunmaktadır {user.name}
              </span>
            </div>
            <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
              <span style={{ fontSize: 10, color: "#444", letterSpacing: 0.5 }}>{plan.detail}</span>
              <span style={{
                Yazı boyutu: 10, harf aralığı: 1, metin dönüştürme: "büyük harf",
                renk: plan.color, kenarlık: `1px düz ${plan.color}44`,
