            </div>
          </div>

          {/* Mesajlar */}
          <div style={{
            dolgu: "24px", minimum yükseklik: 520, maksimum yükseklik: 620,
            taşmaY: "otomatik", görüntüleme: "esnek", esneklikYönü: "sütun", boşluk: 20,
          }}>
            {mesajların uzunluğu === 0 && !yükleniyor && (
              <div style={{ margin: "auto", textAlign: "center", opacity: 0.35 }}>
