                  {m.role === "user" ? "YOU" : "FIT"}
                </div>
                <div style={{
                  maxWidth: "74%", borderRadius: 20,
                  borderTopLeftRadius: m.role === "user" ? 20 : 4,
                  borderTopRightRadius: m.role === "user" ? 4 : 20,
                  arka plan: m.rol === "kullanıcı" ? "#c8f04b" : "#1a1a1a",
                  renk: m.rol === "kullanıcı" ? "#0a0a0a" : "#e8e8e8",
                  border: m.role === "user" ? "none" : "1px solid rgba(255,255,255,0.09)",
                  boxShadow: m.role === "user" ? "0 4px 20px rgba(200,240,75,0.15)" : "0 4px 20px rgba(0,0,0,0.3)",
                  taşma: "gizli",
                }}>
                  <div style={{
                    dolgu: "10px 16px 0", yazı tipi boyutu: 10, yazı tipi kalınlığı: 600, harf aralığı: 1.5,
                    metinDönüştürme: "büyük harf",
                    renk: m.rol === "kullanıcı" ? "rgba(0,0,0,0.35)" : plan.renk,
                  }}>
                    {m.role === "user" ? "You" : "FIT"}
                  </div>
                 
